# ==============================================================================
# ARQUIVO DE CONFIGURAÇÃO DE AMBIENTE
# COPIE ESTE ARQUIVO PARA .env.local E PREENCHA COM SEUS VALORES
# NÃO COMMITE O ARQUIVO .env.local NO GIT!
# ==============================================================================

# ==============================================
# CONEXÃO COM BANCO DE DADOS
# ==============================================
DB_CONNECTION_STRING="Data Source=cadastro_familias.db"

# ==============================================
# AUTENTICAÇÃO JWT
# ==============================================
JWT_SECRET_KEY="INSIRA_SUA_CHAVE_SECRETA_AQUI_32_CARACTERES_OU_MAIS"
JWT_ISSUER="CadastroFamilias.Api"
JWT_AUDIENCE="CadastroFamilias.Web"
JWT_EXPIRE_MINUTES=1440

# ==============================================
# RABBITMQ / MESSAGE BROKER
# ==============================================
RABBITMQ_HOST="amqp://localhost:5672"
RABBITMQ_USERNAME="guest"
RABBITMQ_PASSWORD="guest"

# ==============================================
# REDIS CACHE
# ==============================================
REDIS_CONNECTION_STRING="localhost:6379,abortConnect=false"

# ==============================================
# CORS ORIGENS PERMITIDAS
# ==============================================
CORS_ALLOWED_ORIGINS="http://localhost:5173,https://seu-dominio.com"

# ==============================================
# SERILOG
# ==============================================
SERILOG_MINIMUM_LEVEL="Information"

# ==============================================
# RATE LIMITING
# ==============================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100